DOCKER_IMAGE=renater/sipmediagw:1.7.3
MAIN_APP=${MAIN_APP:-baresip} # baresip, streaming, recording

CPU_PER_GW=4 # Number of CPU cores per gateway:
               # VID_SIZE_WEBRTC=640x360 => 2.5
               # VID_SIZE_WEBRTC=1280x720 => 4

GW_ID=${ID}
TZ=${TZ:-$HOST_TZ}

## Media
WITH_ALSA="true"
AUDIO_ONLY=${AUDIO_ONLY:-}
VID_SIZE_APP=1280x720 # 720p resolution at least to support screen sharing
VID_SIZE_WEBRTC=1280x720

## Webconference
ROOM_NAME=${ROOM}
BROWSING=${BROWSING:-}
WEBRTC_DOMAINS=WEBRTC_DOMAINS="{\
\"jitsi\": { \"name\": \"Webconf de l'état\", \"domain\": \"webconf.numerique.gouv.fr\", \"options\": [\
